[global]
    monitor = DP-1
    follow = none
    width = (0, 400)
    height = (0, 300)
    origin = top-right
    offset = (10, 54)
    notification_limit = 5
    indicate_hidden = yes
    gap_size = 6
    padding = 12
    horizontal_padding = 16
    frame_width = 2
    frame_color = "#cba6f7"
    separator_color = frame
    sort = yes
    idle_threshold = 120
    font = CaskaydiaCove Nerd Font Mono 12
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    max_icon_size = 48
    sticky_history = yes
    history_length = 20
    browser = /usr/bin/xdg-open
    dmenu = /usr/bin/rofi -dmenu -p dunst:
    always_run_script = true
    corner_radius = 10
    progress_bar = true
    progress_bar_height = 4
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 350
    layer = overlay

[progress_bar]
    background = "#313244"
    foreground = "#cba6f7"
    frame_color = "#cba6f7"

[urgency_low]
    background = "#1e1e2e"
    foreground = "#6c7086"
    timeout = 5
    frame_color = "#45475a"

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 8
    frame_color = "#cba6f7"

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f5e0dc"
    timeout = 0
    frame_color = "#f38ba8"
